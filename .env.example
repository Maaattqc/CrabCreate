# Server
HOST=localhost
PORT=3000
CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY=false
NODE_ENV=development

# Database
DB_PATH=./data/db.sqlite
DB_DOCS_PATH=./data/docs

# Authentication
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=your_admin_email_here

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Email (SMTP)
EMAIL_FROM=noreply@example.com
SMTP_HOST=your_smtp_host_here
SMTP_PORT=587
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here

# Cloudflare
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_API_TOKEN=your_cloudflare_api_token_here

# Bitbucket
BITBUCKET_USERNAME=your_bitbucket_username_here
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password_here
BITBUCKET_WORKSPACE=your_bitbucket_workspace_here
BITBUCKET_DEFAULT_REPO=your_bitbucket_default_repo_here
BITBUCKET_WEBHOOK_SECRET=your_bitbucket_webhook_secret_here

# GitHub (auto repo)
AUTO_REPO_GITHUB_OWNER=your_github_owner_here
AUTO_REPO_GITHUB_TOKEN=your_github_token_here

# Repos
REPOS_CLONE_PATH=./repos

# Staging
STAGING_BASE_URL=your_staging_base_url_here

# Security
SECRETS_ENCRYPTION_KEY=your_encryption_key_here

# Chrome (for screenshots/puppeteer)
CHROME_PATH=/usr/bin/chromium

# Ngrok (tunneling)
NGROK_URL=your_ngrok_url_here
